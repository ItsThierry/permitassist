seo/__pycache__/

# Secrets — NEVER commit
.env
.env.*
!.env.example
*.pem
*.key
*credentials*.json
api/__pycache__/
scripts/__pycache__/

api/state_packs/drafts/

# Backups created by inplace edits (never commit historical state)
*.bak-*
*.bak-pre-*

# Local data caches and SQLite runtime DBs (regenerable from sources)
data/co-est2024-alldata.csv
data/sub-est2024.csv
data/cache.db
data/cache.db.*
data/serper_cache.db
data/ip_lookups.db
# verified_cities.db is the canonical 5,260-AHJ snapshot (cities + counties).
# It IS tracked in git so Railway can serve /api/verified-cities at deploy time.
# It's regenerated infrequently (when scripts/city-coverage-expander.py runs) so
# it doesn't churn like cache.db. Backups (verified_cities.db.bak-*) stay ignored.
data/verified_cities.db.*
artifacts/
tests/__pycache__/
